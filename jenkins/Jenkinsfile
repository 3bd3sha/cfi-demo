// CFI Trading Platform - Jenkins Pipeline
// Demonstrates CI/CD with monitoring integration

pipeline {
    agent any
    
    environment {
        DOCKER_IMAGE = "cfi/trading-api"
        PROMETHEUS_URL = "http://prometheus:9090"
        GRAFANA_URL = "http://grafana:3000"
    }
    
    stages {
        stage('Build') {
            steps {
                echo '🔨 Building Docker image...'
                script {
                    docker.build("${DOCKER_IMAGE}:${BUILD_NUMBER}")
                }
            }
        }
        
        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                sh '''
                    echo "Running unit tests..."
                    echo "Running integration tests..."
                    echo "✓ All tests passed"
                '''
            }
        }
        
        stage('Security Scan') {
            steps {
                echo '🔍 Running security scan...'
                sh '''
                    echo "Scanning for vulnerabilities..."
                    echo "✓ No critical vulnerabilities found"
                '''
            }
        }
        
        stage('Deploy to Staging') {
            steps {
                echo '🚀 Deploying to staging...'
                sh '''
                    echo "Deploying to staging environment..."
                    echo "✓ Staging deployment complete"
                '''
            }
        }
        
        stage('Smoke Tests') {
            steps {
                echo '💨 Running smoke tests...'
                sh '''
                    echo "Testing /health endpoint..."
                    echo "Testing /metrics endpoint..."
                    echo "✓ Smoke tests passed"
                '''
            }
        }
        
        stage('Deploy Canary') {
            steps {
                echo '🕯️ Deploying canary (10% traffic)...'
                sh '''
                    echo "Deploying canary to production..."
                    echo "Scaling canary to 10% traffic..."
                    echo "✓ Canary deployed"
                '''
            }
        }
        
        stage('Monitor Canary') {
            steps {
                echo '📊 Monitoring canary health...'
                script {
                    // Simulate 10 minutes of monitoring
                    for (int i = 1; i <= 5; i++) {
                        echo "Health check ${i}/5..."
                        
                        // Check error rate
                        sh """
                            echo "Checking canary error rate..."
                            echo "Canary errors: 0.01% (threshold: 2x stable)"
                        """
                        
                        // Check latency
                        sh """
                            echo "Checking canary latency..."
                            echo "Canary P95: 150ms (threshold: 1.5x stable)"
                        """
                        
                        // Check order success
                        sh """
                            echo "Checking order success rate..."
                            echo "Success rate: 99.99% (threshold: 99.99%)"
                        """
                        
                        echo "✓ Health check ${i} passed"
                        sleep(time: 5, unit: 'SECONDS')
                    }
                    echo "✓ All canary health checks passed!"
                }
            }
        }
        
        stage('Promote to Production') {
            steps {
                echo '🎉 Promoting to 100% production...'
                sh '''
                    echo "Scaling canary to 50%..."
                    sleep 10
                    echo "Scaling canary to 100%..."
                    sleep 10
                    echo "✓ Production deployment complete"
                '''
            }
        }
        
        stage('Create Grafana Annotation') {
            steps {
                echo '📝 Creating deployment annotation...'
                sh '''
                    echo "Posting annotation to Grafana..."
                    echo "✓ Annotation created"
                '''
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully!'
            echo '📊 Deployment metrics recorded'
            echo '🎯 All monitoring checks passed'
        }
        failure {
            echo '❌ Pipeline failed!'
            echo '🔄 Initiating automatic rollback...'
        }
    }
}
